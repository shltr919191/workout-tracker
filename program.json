{
  "phase_info": {
    "Technik & Volumen": {
      "goal": "Bewegungsmuster einschleifen, Basisvolumen aufbauen",
      "weeks": "1–3"
    },
    "Kraft & Progression": {
      "goal": "Laststeigerung bei Compound-Übungen, 4 Sätze",
      "weeks": "4–6"
    },
    "Intensität": {
      "goal": "Maximale Intensität, reduzierte Wiederholungen",
      "weeks": "7–9"
    },
    "Peak & Volumen": {
      "goal": "Kombination Stärke + Hypertrophie, höchste Last",
      "weeks": "10–11"
    },
    "Deload": {
      "goal": "60–70 % Volumen, aktive Regeneration",
      "weeks": "12"
    }
  },
  "progression_rules": [
    "Progressive Overload: Wenn du alle Wdh. der oberen Grenze sauber schaffst → nächste Einheit Gewicht erhöhen (+2,5–5 kg Compound / +1–2,5 kg Isolation).",
    "Phase 1 (W1–3): Technik-Fokus, 3 Sätze. Gewicht konservativ wählen, RIR 3–4.",
    "Phase 2 (W4–6): 4 Sätze Compound, 3 Sätze Iso. Rep-Range sinkt, Last steigt. RIR 2–3.",
    "Phase 3 (W7–9): 4 Sätze überall. Intensität hoch, RIR 1–2.",
    "Phase 4 (W10–11): Höchste absolute Last. RIR 0–1 auf Hauptübungen.",
    "Deload (W12): Alle Gewichte –30–40 %, Sätze 3. Keine PRs jagen.",
    "Beinvolumen: Moderat gehalten wegen Rennrad. Bei wenig Rennrad-Wochen BSS auf 4 Sätze erhöhen."
  ],
